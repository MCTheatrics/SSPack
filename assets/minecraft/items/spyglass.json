{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "1000",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:using_item",
          "on_true": { "type": "minecraft:model", "model": "sscore:item/hadestown/metalcups_raised" },
          "on_false": { "type": "minecraft:model", "model": "sscore:item/hadestown/metalcups" }
        }
      },
      {
        "when": "1001",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:using_item",
          "on_true": { "type": "minecraft:model", "model": "sscore:item/hadestown/fatelantern" },
          "on_false": { "type": "minecraft:model", "model": "sscore:item/hadestown/fatelantern" }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/spyglass"
    }
  }
}
